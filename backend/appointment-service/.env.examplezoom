# Zoom credentials for appointment-service telemedicine link generation
# Copy this file to .env in the same folder and fill values.

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_USER_ID=me

# Optional telemedicine settings
telemed.provider=ZOOM
zoom.use-doctor-host=false
zoom.meeting.duration-minutes=30
zoom.meeting.timezone=UTC
